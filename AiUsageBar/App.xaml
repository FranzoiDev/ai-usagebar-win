<Application
    x:Class="AiUsageBar.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AiUsageBar"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI: Fluent control styles + dark theme. -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <local:LevelToBrushConverter x:Key="LevelToBrush" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Palette mirrors the original Win32 dark theme. -->
            <SolidColorBrush x:Key="BgBrush" Color="#16171D" />
            <SolidColorBrush x:Key="CardBrush" Color="#262934" />
            <SolidColorBrush x:Key="LineBrush" Color="#2E3140" />
            <SolidColorBrush x:Key="TextBrush" Color="#E7E9F0" />
            <SolidColorBrush x:Key="MutedBrush" Color="#9AA0B4" />
            <SolidColorBrush x:Key="AccentBrush" Color="#6D8BFF" />
            <SolidColorBrush x:Key="TrackBrush" Color="#333745" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FF8A80" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
