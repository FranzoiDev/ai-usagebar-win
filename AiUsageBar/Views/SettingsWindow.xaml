<ui:FluentWindow
    x:Class="AiUsageBar.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="AI Usage — Settings"
    Width="580"
    Height="780"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="AI Usage — Settings" />

        <ScrollViewer Grid.Row="1" Padding="18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Refresh interval (seconds)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4" />
                <ui:NumberBox
                    x:Name="PollBox"
                    Minimum="15"
                    Maximum="86400"
                    SmallChange="15"
                    MaxDecimalPlaces="0"
                    Width="160"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12" />

                <TextBlock Text="Primary (tray tooltip)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4" />
                <ComboBox x:Name="PrimaryBox" Width="220" HorizontalAlignment="Left" Margin="0,0,0,8" />

                <CheckBox
                    x:Name="StartupBox"
                    Content="Start with Windows"
                    Foreground="{StaticResource TextBrush}"
                    Margin="0,4,0,4" />

                <CheckBox
                    x:Name="RefreshBox"
                    Content="Auto-refresh Claude / Codex tokens"
                    Foreground="{StaticResource TextBrush}"
                    Margin="0,4,0,2" />
                <TextBlock
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"
                    TextWrapping="Wrap"
                    Margin="24,0,0,4"
                    Text="Heads-up: this rotates the OAuth tokens the Claude and Codex CLIs store on disk. A CLI that is signed in elsewhere can lose its session and need a re-login the next time you use it. Leave this off unless you want the app to keep the tokens fresh for you." />

                <ItemsControl x:Name="VendorsList" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox
                                        Content="{Binding NameWithBadge}"
                                        IsChecked="{Binding Enabled, Mode=TwoWay}"
                                        Foreground="{StaticResource TextBrush}"
                                        Margin="0,0,0,6" />

                                    <TextBlock
                                        Text="{Binding Status}"
                                        Foreground="{StaticResource MutedBrush}"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        Margin="0,0,0,6"
                                        Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}" />

                                    <!-- API-key vendors -->
                                    <StackPanel Visibility="{Binding IsApiKey, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Environment variable" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding ApiKeyEnvText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="260" HorizontalAlignment="Left" Margin="0,0,0,4" />

                                        <TextBlock Text="API key (optional — overrides env var)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,4" />
                                        <ui:PasswordBox Password="{Binding ApiKeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

                                        <StackPanel Visibility="{Binding ShowPlanTier, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Plan tier (display only)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,4" />
                                            <TextBox Text="{Binding PlanTierText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- OAuth vendors -->
                                    <TextBlock
                                        Text="{Binding Hint}"
                                        Foreground="{StaticResource MutedBrush}"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding IsOAuth, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18">
            <ui:Button Content="Close" Click="OnClose" Margin="0,0,10,0" />
            <ui:Button Content="Save" Appearance="Primary" Click="OnSave" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
