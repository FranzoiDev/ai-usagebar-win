<Window
    x:Class="AiUsageBar.Views.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    SizeToContent="WidthAndHeight">

    <Border Width="360" Padding="14" Background="{StaticResource BgBrush}" CornerRadius="8">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Empty state -->
            <TextBlock
                x:Name="EmptyLabel"
                Grid.Row="0"
                Foreground="{StaticResource MutedBrush}"
                TextWrapping="Wrap"
                Visibility="Collapsed"
                Text="No models configured.&#x0a;Open Settings to add an API key." />

            <!-- Vendor cards -->
            <ItemsControl x:Name="VendorsList" Grid.Row="0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding Plan}"
                                        Foreground="{StaticResource MutedBrush}"
                                        FontSize="12"
                                        HorizontalAlignment="Right"
                                        Visibility="{Binding HasPlan, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>

                                <TextBlock
                                    Text="{Binding Message}"
                                    Foreground="{StaticResource DangerBrush}"
                                    TextWrapping="Wrap"
                                    FontSize="12"
                                    Margin="0,0,0,6"
                                    Visibility="{Binding HasMessage, Converter={StaticResource BoolToVisibility}}" />

                                <!-- Progress bars -->
                                <ItemsControl ItemsSource="{Binding Bars}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2,0,2">
                                                <Grid Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                                                </Grid>
                                                <ProgressBar
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding Pct}"
                                                    Height="8"
                                                    Background="{StaticResource TrackBrush}"
                                                    Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Facts -->
                                <ItemsControl ItemsSource="{Binding Facts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,1,0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Refresh" Margin="0,0,3,0" HorizontalAlignment="Stretch" Click="OnRefresh" />
                <Button Grid.Column="1" Content="Settings" Margin="3,0,3,0" HorizontalAlignment="Stretch" Click="OnSettings" />
                <Button Grid.Column="2" Content="Quit" Margin="3,0,0,0" HorizontalAlignment="Stretch" Click="OnQuit" />
            </Grid>
        </Grid>
    </Border>
</Window>
