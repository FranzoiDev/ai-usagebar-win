<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AiUsageBar.Views.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AiUsageBar.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Width="360" Padding="14" Background="{StaticResource BgBrush}" RowSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Empty state -->
        <TextBlock
            x:Name="EmptyLabel"
            Grid.Row="0"
            Foreground="{StaticResource MutedBrush}"
            TextWrapping="Wrap"
            Visibility="Collapsed"
            Text="No models configured.&#x0a;Open Settings to add an API key." />

        <!-- Vendor cards -->
        <ItemsControl x:Name="VendorsList" Grid.Row="0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding Plan}"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="12"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding HasPlan, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>

                            <TextBlock
                                Text="{Binding Message}"
                                Foreground="{StaticResource DangerBrush}"
                                TextWrapping="Wrap"
                                FontSize="12"
                                Visibility="{Binding HasMessage, Converter={StaticResource BoolToVisibility}}" />

                            <!-- Progress bars -->
                            <ItemsControl ItemsSource="{Binding Bars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,2" Spacing="2">
                                            <Grid>
                                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                                            </Grid>
                                            <ProgressBar
                                                Minimum="0"
                                                Maximum="100"
                                                Value="{Binding Pct}"
                                                Height="8"
                                                Background="{StaticResource TrackBrush}"
                                                Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Facts -->
                            <ItemsControl ItemsSource="{Binding Facts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,1,0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Footer -->
        <Grid Grid.Row="1" ColumnSpacing="6" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Refresh" HorizontalAlignment="Stretch" Click="OnRefresh" />
            <Button Grid.Column="1" Content="Settings" HorizontalAlignment="Stretch" Click="OnSettings" />
            <Button Grid.Column="2" Content="Quit" HorizontalAlignment="Stretch" Click="OnQuit" />
        </Grid>
    </Grid>
</Window>
